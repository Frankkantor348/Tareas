@model Tareas.Models.ViewModels.CalificarEntregaViewModel

@{
    ViewData["Title"] = "Calificar Entrega";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-warning text-white">
                    <h3 class="mb-0"><i class="fas fa-star me-2"></i>@ViewData["Title"]</h3>
                </div>
                <div class="card-body">
                    <div class="alert alert-info mb-4">
                        <div class="row">
                            <div class="col-md-6">
                                <strong>Tarea:</strong> @Model.TituloTarea<br />
                                <strong>Estudiante:</strong> @Model.NombreEstudiante
                            </div>
                            <div class="col-md-6">
                                <strong>Fecha de entrega:</strong> @Model.FechaEntrega.ToString("dd/MM/yyyy HH:mm")<br />
                                @if (!string.IsNullOrEmpty(Model.NombreArchivo))
                                {
                                    <strong>Archivo:</strong>
                                    <a asp-action="Descargar" asp-route-id="@Model.EntregaId" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-download"></i> @Model.NombreArchivo
                                    </a>
                                }
                            </div>
                        </div>
                    </div>

                    <form asp-action="Calificar" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="EntregaId" />
                        <input type="hidden" asp-for="TareaId" />

                        <div class="mb-3">
                            <label asp-for="Calificacion" class="form-label fw-bold"></label>
                            <div class="input-group">
                                <input asp-for="Calificacion" class="form-control form-control-lg" type="number" min="0" max="100" step="0.1" />
                                <span class="input-group-text">/ 100</span>
                            </div>
                            <span asp-validation-for="Calificacion" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="RetroalimentacionDocente" class="form-label fw-bold">Retroalimentación</label>
                            <textarea asp-for="RetroalimentacionDocente" class="form-control" rows="5"
                                      placeholder="Escribe comentarios, sugerencias de mejora, observaciones..."></textarea>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Tarea" asp-route-id="@Model.TareaId" class="btn btn-secondary">
                                <i class="fas fa-arrow-left me-1"></i>Volver a entregas
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-1"></i>Guardar calificación
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}