@model IEnumerable<Tareas.Models.Entrega>
@{
    ViewData["Title"] = "Entregas de la Tarea";
    var tarea = ViewBag.Tarea as Tareas.Models.Tarea;
    var estudiantes = ViewBag.Estudiantes as Dictionary<string, string> ?? new Dictionary<string, string>();
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h3 class="mb-0"><i class="fas fa-clipboard-list me-2"></i>@ViewData["Title"]</h3>
                    <a asp-action="Detalles" asp-controller="Tareas" asp-route-id="@tarea?.Id" class="btn btn-light btn-sm">
                        <i class="fas fa-arrow-left me-1"></i>Volver a la tarea
                    </a>
                </div>
                <div class="card-body">
                    @if (tarea != null)
                    {
                        <div class="alert alert-info mb-4">
                            <h5 class="alert-heading"><i class="fas fa-info-circle me-2"></i>@tarea.Titulo</h5>
                            <p class="mb-0">@tarea.Descripcion</p>
                            <hr />
                            <div class="row">
                                <div class="col-md-6">
                                    <small><strong>Fecha límite:</strong> @tarea.FechaLimite.ToString("dd/MM/yyyy")</small>
                                </div>
                                <div class="col-md-6">
                                    <small><strong>Total entregas:</strong> @Model.Count()</small>
                                </div>
                            </div>
                        </div>
                    }

                    @if (!Model.Any())
                    {
                        <div class="alert alert-warning">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            No hay entregas para esta tarea aún.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Estudiante</th>
                                        <th>Fecha de entrega</th>
                                        <th>Comentario</th>
                                        <th>Archivo</th>
                                        <th>Calificación</th>
                                        <th>Estado</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var entrega in Model)
                                    {
                                        <tr>
                                            <td>
                                                @if (estudiantes.ContainsKey(entrega.EstudianteId))
                                                {
                                                    @estudiantes[entrega.EstudianteId]
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Usuario @entrega.EstudianteId.Substring(0, 8)...</span>
                                                }
                                            </td>
                                            <td>@entrega.FechaEntrega.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(entrega.ComentarioEstudiante))
                                                {
                                                    <span>@entrega.ComentarioEstudiante</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(entrega.RutaArchivo))
                                                {
                                                    <a asp-action="Descargar" asp-controller="Entregas" asp-route-id="@entrega.Id" class="btn btn-sm btn-outline-primary" target="_blank">
                                                        <i class="fas fa-download"></i> Ver
                                                    </a>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (entrega.Calificacion.HasValue)
                                                {
                                                    <span class="badge bg-success">@entrega.Calificacion.Value.ToString("0.00")</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning">Pendiente</span>
                                                }
                                            </td>
                                            <td>
                                                @if (entrega.Calificacion.HasValue)
                                                {
                                                    <span class="badge bg-success">Calificada</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning">Por calificar</span>
                                                }
                                            </td>
                                            <td>
                                                @if (!entrega.Calificacion.HasValue)
                                                {
                                                    <a asp-action="Calificar" asp-controller="Entregas" asp-route-id="@entrega.Id" class="btn btn-sm btn-warning">
                                                        <i class="fas fa-star"></i> Calificar
                                                    </a>
                                                }
                                                else
                                                {
                                                    <a asp-action="Calificar" asp-controller="Entregas" asp-route-id="@entrega.Id" class="btn btn-sm btn-outline-secondary">
                                                        <i class="fas fa-edit"></i> Editar
                                                    </a>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
