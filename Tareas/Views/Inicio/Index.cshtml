@model IEnumerable<Tareas.Models.Tarea>  

<h3>LISTA DE TAREAS REGISTRADAS</h3>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Descripción</th>
            <th>Prioridad</th>
            <th>Estado</th>
            <th>Vencimiento</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var tarea in Model)
        {
            <tr>
                <td>@tarea.Nombre</td>
                <td>@tarea.Descripcion</td>
                <td><span class="badge bg-@GetPrioridadBadgeClass(tarea.Prioridad)">@tarea.Prioridad.ToString()</span></td>
                <td><span class="badge bg-@GetEstadoBadgeClass(tarea.Estado)">@tarea.Estado.ToString()</span></td>
                <td>@(tarea.FechaVencimiento?.ToString("yyyy-MM-dd") ?? "—")</td>
                <td>
                    <a href="@Url.Action("Detalles", "Inicio", new { id = tarea.Id })" class="btn btn-info btn-sm">Detalles</a>
                    <a href="@Url.Action("Editar", "Inicio", new { id = tarea.Id })" class="btn btn-warning btn-sm">Editar</a>
                    <form action="@Url.Action("Eliminar", "Inicio", new { id = tarea.Id })" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<a href="@Url.Action("Crear", "Inicio")" class="btn btn-success">Crear Nueva Tarea</a>

@functions {
    private string GetEstadoBadgeClass(Tareas.Models.EstadoTarea estado)
    {
        return estado switch
        {
            Tareas.Models.EstadoTarea.Pendiente => "warning",
            Tareas.Models.EstadoTarea.EnProgreso => "info",
            Tareas.Models.EstadoTarea.Completada => "success",
            _ => "secondary"
        };
    }

    private string GetPrioridadBadgeClass(Tareas.Models.PrioridadTarea prioridad)
    {
        return prioridad switch
        {
            Tareas.Models.PrioridadTarea.Baja => "success",
            Tareas.Models.PrioridadTarea.Media => "warning",
            Tareas.Models.PrioridadTarea.Alta => "danger",
            _ => "secondary"
        };
    }
}












