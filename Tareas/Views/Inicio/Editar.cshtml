@model Tareas.Models.Tarea  

@{
    ViewData["Title"] = "Editar Tarea";
}

<h1>@ViewData["Title"]</h1>

<form method="post" class="form-group">
    @Html.AntiForgeryToken()

    <div class="form-group">
        <label for="Nombre">Nombre</label>
        <input type="text" id="Nombre" name="Nombre" class="form-control" value="@Model.Nombre" required />
    </div>

    <div class="form-group">
        <label for="Descripcion">Descripción</label>
        <textarea id="Descripcion" name="Descripcion" class="form-control" rows="4" required>@Model.Descripcion</textarea>
    </div>
    
    <div class="form-group">
        <label for="FechaCreacion">Fecha de Creación</label>
        <input type="date" id="FechaCreacion" name="FechaCreacion" class="form-control" value="@Model.FechaCreacion.ToString("yyyy-MM-dd")" required />
    </div>

    <div class="form-group">
        <label for="FechaVencimiento">Fecha de Vencimiento</label>
        <input type="date" id="FechaVencimiento" name="FechaVencimiento" class="form-control" value="@(Model.FechaVencimiento?.ToString("yyyy-MM-dd") ?? "")" />
    </div>

    <div class="form-group">
        <label for="Estado">Estado</label>
        <select id="Estado" name="Estado" class="form-control" required>
            <option value="">Seleccione un estado</option>
            <option value="1" selected="@(Model.Estado == Tareas.Models.EstadoTarea.Pendiente)">Pendiente</option>
            <option value="2" selected="@(Model.Estado == Tareas.Models.EstadoTarea.EnProgreso)">En Progreso</option>
            <option value="3" selected="@(Model.Estado == Tareas.Models.EstadoTarea.Completada)">Completada</option>
        </select>
    </div>

    <div class="form-group">
        <label for="Prioridad">Prioridad</label>
        <select id="Prioridad" name="Prioridad" class="form-control" required>
            <option value="">Seleccione una prioridad</option>
            <option value="1" selected="@(Model.Prioridad == Tareas.Models.PrioridadTarea.Baja)">Baja</option>
            <option value="2" selected="@(Model.Prioridad == Tareas.Models.PrioridadTarea.Media)">Media</option>
            <option value="3" selected="@(Model.Prioridad == Tareas.Models.PrioridadTarea.Alta)">Alta</option>
        </select>
    </div>

    <div class="form-group">
        <button type="submit" class="btn btn-primary">Guardar</button>
        <a href="@Url.Action("Index", "Inicio")" class="btn btn-secondary">Cancelar</a>
    </div>
</form>

