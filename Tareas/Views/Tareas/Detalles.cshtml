@model Tareas.Models.Tarea

@{
    ViewData["Title"] = "Detalles de la Tarea";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card shadow">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h3 class="mb-0"><i class="fas fa-info-circle me-2"></i>@ViewData["Title"]</h3>

                    @{
                        string estadoTexto = Model.ColorSemaforo switch
                        {
                            "verde" => "✓ Con tiempo",
                            "amarillo" => "⚠ Próximo a vencer",
                            "rojo" => "‼ Vencida",
                            _ => Model.ColorSemaforo
                        };
                    }
                    <span class="badge bg-@Model.ColorSemaforo fs-6">@estadoTexto</span>
                </div>

                <div class="card-body">
                    <h4>@Model.Titulo</h4>
                    <hr />
                    <p class="lead">@Model.Descripcion</p>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <h6 class="card-subtitle mb-2 text-muted">
                                        <i class="fas fa-calendar-alt me-1"></i>Fecha de publicación
                                    </h6>
                                    <p class="card-text">@Model.FechaPublicacion.ToString("dd/MM/yyyy")</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <h6 class="card-subtitle mb-2 text-muted">
                                        <i class="fas fa-clock me-1"></i>Fecha límite
                                    </h6>
                                    <p class="card-text">@Model.FechaLimite.ToString("dd/MM/yyyy")</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.InstruccionesAdicionales))
                    {
                        <div class="mb-4">
                            <h5><i class="fas fa-clipboard-list me-2"></i>Instrucciones adicionales</h5>
                            <div class="p-3 bg-light rounded">
                                @Model.InstruccionesAdicionales
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.Curso))
                    {
                        <div class="mb-4">
                            <h5><i class="fas fa-users me-2"></i>Curso / Grado</h5>
                            <p>@Model.Curso</p>
                        </div>
                    }

                    <!-- MATERIAL DE APOYO PARA ESTUDIANTES -->
                    @if (User.IsInRole("Estudiante") && !string.IsNullOrEmpty(Model.RutaArchivoApoyo))
                    {
                        <div class="mb-4">
                            <div class="alert alert-info">
                                <h5 class="alert-heading">
                                    <i class="fas fa-paperclip me-2"></i>Material de apoyo
                                </h5>
                                <hr />
                                <p class="mb-2">El profesor ha compartido material adicional:</p>
                                <div class="d-flex align-items-center flex-wrap gap-2">
                                    <a href="@Model.RutaArchivoApoyo" target="_blank" class="btn btn-outline-primary">
                                        <i class="fas fa-download me-2"></i>
                                        Descargar: @(Model.NombreArchivoApoyo ?? "Material de apoyo")
                                    </a>
                                    @if (!string.IsNullOrEmpty(Model.TipoArchivoApoyo))
                                    {
                                        <span class="badge bg-secondary">
                                            @Model.TipoArchivoApoyo.TrimStart('.').ToUpper()
                                        </span>
                                    }
                                </div>
                            </div>
                        </div>
                    }

                    <!-- MATERIAL DE APOYO PARA DOCENTES -->
                    @if (User.IsInRole("Docente") && !string.IsNullOrEmpty(Model.RutaArchivoApoyo))
                    {
                        <div class="mb-4">
                            <div class="alert alert-secondary">
                                <h5 class="alert-heading">
                                    <i class="fas fa-paperclip me-2"></i>Material de apoyo (subido)
                                </h5>
                                <hr />
                                <div class="d-flex align-items-center flex-wrap gap-2">
                                    <a href="@Model.RutaArchivoApoyo" target="_blank" class="btn btn-sm btn-outline-secondary">
                                        <i class="fas fa-eye me-1"></i>Ver archivo
                                    </a>
                                    <span class="text-muted">
                                        <i class="fas fa-file me-1"></i> @Model.NombreArchivoApoyo
                                    </span>
                                    @if (Model.TamañoArchivoApoyo.HasValue)
                                    {
                                        <span class="badge bg-light text-dark">
                                            @(Model.TamañoArchivoApoyo / 1024) KB
                                        </span>
                                    }
                                </div>
                            </div>
                        </div>
                    }

                    <!-- ESTADO DE ENTREGA PARA ESTUDIANTES -->
                    @if (User.IsInRole("Estudiante"))
                    {
                        <div class="alert @(ViewBag.YaEntrego == true ? "alert-success" : "alert-info")">
                            <i class="fas fa-info-circle me-2"></i>
                            @if (ViewBag.YaEntrego == true)
                            {
                                <span>Ya has entregado esta tarea. </span>
                                if (ViewBag.Calificacion != null)
                                {
                                    <span><strong>Calificación: @ViewBag.Calificacion/100</strong></span>
                                }
                                else
                                {
                                    <span><strong>Pendiente de calificación</strong></span>
                                }
                            }
                            else
                            {
                                <span>Aún no has entregado esta tarea.</span>
                                if (Model.FechaLimite.Date < DateTime.Now.Date)
                                {
                                    <span class="text-danger"><strong> (Tarea vencida)</strong></span>
                                }
                            }
                        </div>
                    }

                    <!-- BOTONES DE ACCIÓN POR ROL -->
                    <div class="d-flex justify-content-between align-items-center mt-4">
                        <a asp-action="Index" asp-controller="Tareas" class="btn btn-secondary">
                            <i class="fas fa-arrow-left me-1"></i>Volver
                        </a>

                        <div class="d-flex gap-2">
                            @if (User.IsInRole("Estudiante") && ViewBag.YaEntrego == false && Model.FechaLimite.Date >= DateTime.Now.Date)
                            {
                                <a asp-action="Crear" asp-controller="Entregas" asp-route-id="@Model.Id" class="btn btn-success">
                                    <i class="fas fa-upload me-1"></i>Entregar Tarea
                                </a>
                            }

                            @if (User.IsInRole("Docente"))
                            {
                                <a asp-action="Editar" asp-route-id="@Model.Id" class="btn btn-warning">
                                    <i class="fas fa-edit me-1"></i>Editar
                                </a>
                                <a asp-action="Tarea" asp-controller="Entregas" asp-route-id="@Model.Id" class="btn btn-info">
                                    <i class="fas fa-list me-1"></i>Ver entregas
                                    <span class="badge bg-white text-info ms-1">@(Model.Entregas?.Count ?? 0)</span>
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>