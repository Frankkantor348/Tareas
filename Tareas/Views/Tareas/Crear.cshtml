@model Tareas.Models.ViewModels.TareaViewModel

@{
    ViewData["Title"] = "Publicar Nueva Tarea";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0"><i class="bi bi-plus-circle"></i> @ViewData["Title"]</h3>
                </div>
                <div class="card-body">
                    <form asp-action="Crear" method="post">
                        @Html.AntiForgeryToken()

                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                            </div>
                        }

                        <div class="mb-3">
                            <label asp-for="Titulo" class="form-label"></label>
                            <input asp-for="Titulo" class="form-control" placeholder="Ej: Tarea de matemáticas - Ecuaciones cuadráticas" />
                            <span asp-validation-for="Titulo" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Descripcion" class="form-label"></label>
                            <textarea asp-for="Descripcion" class="form-control" rows="5" placeholder="Describe detalladamente la tarea, incluye instrucciones, ejercicios, etc."></textarea>
                            <span asp-validation-for="Descripcion" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="FechaLimite" class="form-label"></label>
                                <input asp-for="FechaLimite" class="form-control" type="date" min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                                <span asp-validation-for="FechaLimite" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Curso" class="form-label"></label>
                                <input asp-for="Curso" class="form-control" placeholder="Ej: 10A, 11B, Ingeniería Software" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="InstruccionesAdicionales" class="form-label"></label>
                            <textarea asp-for="InstruccionesAdicionales" class="form-control" rows="3" placeholder="Formato de entrega, recomendaciones, materiales de apoyo..."></textarea>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-check-circle"></i> Publicar Tarea
                            </button>
                            <a asp-action="Dashboard" asp-controller="Inicio" class="btn btn-outline-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
