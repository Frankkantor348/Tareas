@model IEnumerable<Tareas.Models.Entrega>

@{
    ViewData["Title"] = "Mis Entregas";
}

<div class="container mt-4">
    <h1 class="mb-4"><i class="bi bi-check-circle"></i> @ViewData["Title"]</h1>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No has realizado ninguna entrega aún.
            <a asp-action="Index" asp-controller="Tareas" class="alert-link">Ver tareas disponibles</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Tarea</th>
                        <th>Fecha de entrega</th>
                        <th>Comentario</th>
                        <th>Archivo</th>
                        <th>Calificación</th>
                        <th>Retroalimentación</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entrega in Model)
                    {
                        <tr>
                            <td>
                                <strong>@entrega.Tarea?.Titulo</strong>
                                <br />
                                <small class="text-muted">@entrega.Tarea?.Descripcion?.Substring(0, Math.Min(50, entrega.Tarea?.Descripcion?.Length ?? 0))...</small>
                            </td>
                            <td>@entrega.FechaEntrega.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @if (!string.IsNullOrEmpty(entrega.ComentarioEstudiante))
                                {
                                    <span>@entrega.ComentarioEstudiante</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(entrega.RutaArchivo))
                                {
                                    <a asp-action="Descargar" asp-controller="Entregas" asp-route-id="@entrega.Id" class="btn btn-sm btn-outline-primary" target="_blank">
                                        <i class="bi bi-download"></i> Ver archivo
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (entrega.Calificacion.HasValue)
                                {
                                    <span class="badge bg-success fs-6">@entrega.Calificacion.Value.ToString("0.00")</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning">Pendiente</span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(entrega.RetroalimentacionDocente))
                                {
                                    <span>@entrega.RetroalimentacionDocente</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (entrega.Calificacion.HasValue)
                                {
                                    <span class="badge bg-success">Calificada</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning">Pendiente de revisión</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <div class="mt-3">
        <a asp-action="Index" asp-controller="Tareas" class="btn btn-primary">
            <i class="bi bi-arrow-left"></i> Volver a tareas
        </a>
    </div>
</div>
